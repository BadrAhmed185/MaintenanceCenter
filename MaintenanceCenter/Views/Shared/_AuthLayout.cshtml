<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مركز صيانة الأجهزة العلمية</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #f4f6f9;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .bg-mis-blue { background-color: #003366 !important; }
        .text-mis-gold { color: #FFD700 !important; }
        .btn-mis { background-color: #003366; color: white; transition: all 0.3s ease; }
        .btn-mis:hover { background-color: #002244; color: #FFD700; transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .auth-card { width: 100%; max-width: 450px; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: white; }
    </style>
</head>
<body>
    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/api-client.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>