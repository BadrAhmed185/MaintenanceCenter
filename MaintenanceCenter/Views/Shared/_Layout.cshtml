<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مركز صيانة الأجهزة العلمية</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #f8f9fa;
        }
        /* MIS Branding Colors */
        .bg-mis-blue { background-color: #003366 !important; }
        .text-mis-gold { color: #FFD700 !important; }
        .btn-mis { background-color: #003366; color: white; }
        .btn-mis:hover { background-color: #002244; color: #FFD700; }

        /* Layout Structure */
        .wrapper { display: flex; width: 100%; height: 100vh; overflow: hidden; }
        .sidebar { width: 250px; background-color: white; border-left: 1px solid #ddd; padding: 20px 0; }
        .sidebar-link { padding: 10px 20px; color: #333; text-decoration: none; display: block; font-weight: 600; }
        .sidebar-link:hover, .sidebar-link.active { background-color: #003366; color: white; }
        .main-content { flex-grow: 1; display: flex; flex-direction: column; overflow-y: auto; }
        .header { background-color: white; border-bottom: 1px solid #ddd; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; }
    </style>
</head>
<body>
    <div class="wrapper">
        <nav class="sidebar">
            <div class="text-center mb-4">
                <h5 class="text-mis-blue fw-bold">مركز الصيانة</h5>
            </div>
            <a href="/Reception" class="sidebar-link active">➕ استلام جهاز جديد</a>
            <a href="/Admin/Dashboard" class="sidebar-link">📋 لوحة تحكم الإدارة</a>
            <a href="/Technician/Workspace" class="sidebar-link">🔬 فحص الأجهزة</a>
        </nav>

        <div class="main-content">
            <header class="header">
                <div>
                    <span class="fw-bold">مرحباً، <span id="currentUserLabel">أحمد (استقبال)</span></span>
                    <button class="btn btn-sm btn-outline-danger ms-3">تسجيل خروج</button>
                </div>
                <div>
                    <span class="fw-bold text-mis-blue">جامعة أسيوط | MIS</span>
                </div>
            </header>

            <main class="p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> 
    <script src="~/js/api-client.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>