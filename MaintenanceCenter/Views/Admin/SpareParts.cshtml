@{
    ViewData["Title"] = "قائمة قطع الغيار";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-mis-blue">⚙️ قائمة تكلفة قطع الغيار</h3>
    <button class="btn btn-mis fw-bold px-4" data-bs-toggle="modal" data-bs-target="#catalogModal">
        ➕ إضافة قطعة جديدة
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-mis-blue text-white">
                <tr>
                    <th>اسم قطعة الغيار</th>
                    <th>التكلفة الحالية (ج.م)</th>
                    <th class="text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody id="catalogTableBody">
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="catalogModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold text-mis-blue">بيانات الصنف</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="catalogForm">
                <div class="modal-body">
                    <input type="hidden" id="ItemId">
                    <div class="mb-3">
                        <label class="form-label fw-bold">الاسم <span class="text-danger">*</span></label>
                        <input type="text" id="ItemName" class="form-control" required minlength="2">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">التكلفة (ج.م) <span class="text-danger">*</span></label>
                        <input type="number" id="ItemCost" class="form-control" required min="0.01" step="0.01">
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-mis px-4">💾 حفظ</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/views/admin/spareparts.js"></script>
}