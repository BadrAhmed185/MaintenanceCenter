@{
    ViewData["Title"] = "شاشة المتابعة المتقدمة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-mis-blue">📊 شاشة المتابعة المتقدمة والتقارير</h3>
    <span class="text-muted">الإدارة / المتابعة</span>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-bold text-mis-blue border-bottom-0 pt-3">
        🔍 محددات البحث والفلاتر
    </div>
    <div class="card-body">
        <form id="filterForm" class="row g-3">
            <div class="col-md-4">
                <label class="form-label small fw-bold">بحث (كود الجهاز أو اسم الجهاز)</label>
                <input type="text" id="SearchTerm" class="form-control" placeholder="ابحث هنا...">
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold">حالة الجهاز</label>
                <select id="Status" class="form-select">
                    <option value="">-- كل الحالات --</option>
                    <option value="0">🔵 تم الاستلام (بانتظار التوجيه)</option>
                    <option value="1">🟡 تحت الفحص (لدى الفني)</option>
                    <option value="2">🟣 المقايسة جاهزة (بانتظار الدفع)</option>
                    <option value="3">🟠 جاري التصليح (تم الدفع)</option>
                    <option value="4">🟢 جاهز للاستلام</option>
                    <option value="5">⚪ تم التسليم (مغلق)</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold">الورشة</label>
                <select id="WorkshopId" class="form-select">
                    <option value="">-- كل الورش --</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold">الفني المختص</label>
                <select id="TechnicianId" class="form-select" disabled>
                    <option value="">-- اختر الورشة أولاً --</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold">من تاريخ (الاستلام)</label>
                <input type="date" id="StartDate" class="form-control">
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold">إلى تاريخ</label>
                <input type="date" id="EndDate" class="form-control">
            </div>

            <div class="col-12 text-end mt-3">
                <button type="reset" id="resetBtn" class="btn btn-outline-secondary px-4 me-2">🔄 إعادة ضبط</button>
                <button type="submit" id="searchBtn" class="btn btn-mis px-5 fw-bold">🔍 تطبيق الفلاتر</button>
            </div>
        </form>
    </div>
</div>


<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-mis-blue text-white">
                    <tr>
                        <th>الكود</th>
                        <th>الجهاز والجهة</th>
                        <th>الورشة والفني</th>
                        <th>تاريخ الاستلام</th>
                        <th>الحالة</th>
                        <th class="text-center">التكلفة (ج.م)</th>
                    </tr>
                </thead>
                <tbody id="monitoringTableBody">
                    <tr><td colspan="6" class="text-center py-5">جاري التحميل...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
        <span class="text-muted small" id="pageInfo">الصفحة 1</span>
        <div>
            <button class="btn btn-sm btn-outline-secondary px-3" id="prevPageBtn" disabled>السابق</button>
            <button class="btn btn-sm btn-mis px-3 ms-1" id="nextPageBtn" disabled>التالي</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/views/admin/monitoring.js"></script>
}